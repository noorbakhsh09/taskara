FROM oven/bun:1.2-alpine AS deps

WORKDIR /app

COPY package.json bun.lock bunfig.toml tsconfig.base.json ./
COPY apps/api/package.json apps/api/package.json
COPY apps/web/package.json apps/web/package.json
COPY apps/mattermost-bot/package.json apps/mattermost-bot/package.json
COPY apps/menubar/package.json apps/menubar/package.json
COPY packages/db/package.json packages/db/package.json
COPY packages/shared/package.json packages/shared/package.json
COPY plugins/taskara-agent/package.json plugins/taskara-agent/package.json

RUN bun install --filter @taskara/web

FROM deps AS build

COPY apps/web apps/web
COPY packages/shared packages/shared

RUN bun run --filter @taskara/web build

FROM nginx:1.27-alpine AS runtime

COPY docker/nginx-web.conf /etc/nginx/conf.d/default.conf
COPY docker/web-entrypoint.sh /docker-entrypoint.d/99-taskara-env.sh
COPY --from=build /app/apps/web/dist /usr/share/nginx/html

RUN chmod +x /docker-entrypoint.d/99-taskara-env.sh

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1/health >/dev/null || exit 1
